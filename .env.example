# Copy this file to .env and fill in your values
# Never commit .env to git

# ─── Supabase ───────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend ────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=

# ─── Frontend (Vite exposes VITE_ vars) ─
VITE_API_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
